        <AssemblyVersion>0.0.4.0</AssemblyVersion>
        <FileVersion>0.0.4.0</FileVersion>

        <AssemblyName>AetherTrail</AssemblyName>
        <RootNamespace>AetherTrail</RootNamespace>

